    <content><![CDATA[<h1 id="坦克"><a href="#坦克" class="headerlink" title="坦克"></a>坦克</h1><figure class="highlight java"><table><tr><td class="code"><pre><span class="line"><span class="comment">/**</span></span><br><span class="line"><span class="comment"> * <span class="doctag">@author</span> : DolphinHome</span></span><br><span class="line"><span class="comment"> * <span class="doctag">@date</span> : 2020/11/4  14:20</span></span><br><span class="line"><span class="comment"> */</span></span><br><span class="line"><span class="keyword">public</span> <span class="class"><span class="keyword">class</span> <span class="title">Test</span> </span>&#123;</span><br><span class="line">    <span class="keyword">static</span> <span class="class"><span class="keyword">class</span> <span class="title">Tank</span> </span>&#123;</span><br><span class="line">        <span class="keyword">private</span> String name;<span class="comment">//坦克名称</span></span><br><span class="line">        <span class="keyword">private</span> <span class="keyword">double</span> speed;<span class="comment">//速度</span></span><br><span class="line">        <span class="keyword">private</span> <span class="keyword">int</span> bulletAmount;<span class="comment">//炮弹</span></span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="title">Tank</span><span class="params">()</span> </span>&#123;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="title">Tank</span><span class="params">(String name, <span class="keyword">double</span> speed, <span class="keyword">int</span> bulletAmount)</span> </span>&#123;</span><br><span class="line">            <span class="keyword">this</span>.name = name;</span><br><span class="line">            <span class="keyword">this</span>.speed = speed;</span><br><span class="line">            <span class="keyword">this</span>.bulletAmount = bulletAmount;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">speedUP</span><span class="params">(<span class="keyword">double</span> speed)</span> </span>&#123;</span><br><span class="line">            <span class="keyword">this</span>.speed = speed;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">speedDown</span><span class="params">(<span class="keyword">double</span> speed)</span> </span>&#123;</span><br><span class="line">            <span class="keyword">this</span>.speed = speed;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">double</span> <span class="title">getSpeed</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            <span class="keyword">return</span> speed;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">showSpeed</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            System.out.println(<span class="keyword">this</span>.name + <span class="string">&quot;当前速度：&quot;</span> + <span class="keyword">this</span>.speed);</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">fire</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            <span class="keyword">if</span> (<span class="keyword">this</span>.bulletAmount &gt; <span class="number">0</span>) &#123;</span><br><span class="line">                --<span class="keyword">this</span>.bulletAmount;</span><br><span class="line">                System.out.println(<span class="keyword">this</span>.name + <span class="string">&quot;开火：\n\t打出一发炮弹\t剩余炮弹：&quot;</span> + <span class="keyword">this</span>.bulletAmount);</span><br><span class="line">            &#125; <span class="keyword">else</span> &#123;</span><br><span class="line">                System.out.println(<span class="string">&quot;\t没有炮弹，无法开火&quot;</span>);</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="comment">//<span class="doctag">TODO:</span> get set</span></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">int</span> <span class="title">getBulletAmount</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            <span class="keyword">return</span> bulletAmount;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">showBulletAmount</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            System.out.println(<span class="keyword">this</span>.name + <span class="string">&quot;的炮弹数量：&quot;</span> + <span class="keyword">this</span>.bulletAmount);</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">setBulletAmount</span><span class="params">(<span class="keyword">int</span> bulletAmount)</span> </span>&#123;</span><br><span class="line">            <span class="keyword">this</span>.bulletAmount = bulletAmount;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">    &#125;</span><br><span class="line"></span><br><span class="line">    <span class="keyword">static</span> <span class="class"><span class="keyword">class</span> <span class="title">Fight</span> </span>&#123;</span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">static</span> <span class="keyword">void</span> <span class="title">main</span><span class="params">(String[] args)</span> </span>&#123;</span><br><span class="line">            Tank tank1 = <span class="keyword">new</span> Tank(<span class="string">&quot;tank1&quot;</span>, <span class="number">80</span>, <span class="number">10</span>);</span><br><span class="line">            Tank tank2 = <span class="keyword">new</span> Tank(<span class="string">&quot;tank2&quot;</span>, <span class="number">90</span>, <span class="number">10</span>);</span><br><span class="line">            tank1.showBulletAmount();</span><br><span class="line">            tank2.showBulletAmount();</span><br><span class="line">            tank1.showSpeed();</span><br><span class="line">            tank2.showSpeed();</span><br><span class="line">            tank1.speedDown(<span class="number">65</span>);</span><br><span class="line">            tank2.speedDown(<span class="number">60</span>);</span><br><span class="line">            tank1.showSpeed();</span><br><span class="line">            tank2.showSpeed();</span><br><span class="line">            tank1.fire();</span><br><span class="line">            <span class="keyword">while</span> (tank2.getBulletAmount() &gt; <span class="number">0</span>) &#123;</span><br><span class="line">                tank2.fire();</span><br><span class="line">            &#125;</span><br><span class="line">            tank1.showBulletAmount();</span><br><span class="line">            tank2.showBulletAmount();</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br></pre></td></tr></table></figure>

<p>输出结果：</p>
<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">tank1的炮弹数量：10</span><br><span class="line">tank2的炮弹数量：10</span><br><span class="line">tank1当前速度：80.0</span><br><span class="line">tank2当前速度：90.0</span><br><span class="line">tank1当前速度：65.0</span><br><span class="line">tank2当前速度：60.0</span><br><span class="line">tank1开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：9</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：9</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：8</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：7</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：6</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：5</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：4</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：3</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：2</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：1</span><br><span class="line">tank2开火：</span><br><span class="line">	打出一发炮弹	剩余炮弹：0</span><br><span class="line">tank1的炮弹数量：9</span><br><span class="line">tank2的炮弹数量：0</span><br></pre></td></tr></table></figure>



<h1 id="村庄"><a href="#村庄" class="headerlink" title="村庄"></a>村庄</h1><figure class="highlight java"><table><tr><td class="code"><pre><span class="line"><span class="comment">/**</span></span><br><span class="line"><span class="comment"> * <span class="doctag">@author</span> : DolphinHome</span></span><br><span class="line"><span class="comment"> * <span class="doctag">@date</span> : 2020/11/4  14:20</span></span><br><span class="line"><span class="comment"> */</span></span><br><span class="line"><span class="keyword">public</span> <span class="class"><span class="keyword">class</span> <span class="title">Test2</span> </span>&#123;</span><br><span class="line">    <span class="keyword">static</span> <span class="class"><span class="keyword">class</span> <span class="title">Village</span> </span>&#123;<span class="comment">//村</span></span><br><span class="line">        <span class="keyword">private</span> String villageName;<span class="comment">//村名</span></span><br><span class="line">        <span class="keyword">private</span> <span class="keyword">int</span> personNum;<span class="comment">//人口</span></span><br><span class="line">        <span class="keyword">private</span> <span class="keyword">static</span> <span class="keyword">int</span> waterAmount;<span class="comment">//水量</span></span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="title">Village</span><span class="params">()</span> </span>&#123;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="title">Village</span><span class="params">(String villageName, <span class="keyword">int</span> personNum)</span> </span>&#123;</span><br><span class="line">            <span class="keyword">this</span>.villageName = villageName;</span><br><span class="line">            <span class="keyword">this</span>.personNum = personNum;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">static</span> <span class="keyword">int</span> <span class="title">getWaterAmount</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            <span class="keyword">return</span> waterAmount;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">showWaterAmount</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            System.out.println(<span class="keyword">this</span>.villageName + <span class="string">&quot;发现水井里有：&quot;</span> + waterAmount + <span class="string">&quot;升水&quot;</span>);</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">static</span> <span class="keyword">void</span> <span class="title">AllLookWaterAmount</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            System.out.println(<span class="string">&quot;水井里有：&quot;</span> + waterAmount + <span class="string">&quot;升水&quot;</span>);</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">static</span> <span class="keyword">void</span> <span class="title">setWaterAmount</span><span class="params">(<span class="keyword">int</span> waterAmount)</span> </span>&#123;</span><br><span class="line">            Village.waterAmount = waterAmount;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">drinkWater</span><span class="params">(<span class="keyword">int</span> waterAmount)</span> </span>&#123;</span><br><span class="line">            System.out.println(<span class="keyword">this</span>.villageName + <span class="string">&quot;喝了：&quot;</span> + waterAmount + <span class="string">&quot;升水&quot;</span>);</span><br><span class="line">            Village.waterAmount -= waterAmount;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">void</span> <span class="title">showPersonNum</span><span class="params">()</span> </span>&#123;</span><br><span class="line">            System.out.println(<span class="keyword">this</span>.villageName + <span class="string">&quot;的人口：&quot;</span> + <span class="keyword">this</span>.personNum);</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line"></span><br><span class="line">    <span class="keyword">static</span> <span class="class"><span class="keyword">class</span> <span class="title">Land</span> </span>&#123;<span class="comment">//土地</span></span><br><span class="line"></span><br><span class="line">        <span class="function"><span class="keyword">public</span> <span class="keyword">static</span> <span class="keyword">void</span> <span class="title">main</span><span class="params">(String[] args)</span> </span>&#123;</span><br><span class="line">            Village.setWaterAmount(<span class="number">200</span>);</span><br><span class="line">            Village.AllLookWaterAmount();</span><br><span class="line">            Village v_z = <span class="keyword">new</span> Village(<span class="string">&quot;赵庄&quot;</span>, <span class="number">80</span>);</span><br><span class="line">            Village v_m = <span class="keyword">new</span> Village(<span class="string">&quot;马家河子&quot;</span>, <span class="number">120</span>);</span><br><span class="line">            v_z.drinkWater(<span class="number">50</span>);</span><br><span class="line">            v_m.showWaterAmount();</span><br><span class="line">            v_m.drinkWater(<span class="number">100</span>);</span><br><span class="line">            v_z.showWaterAmount();</span><br><span class="line">            v_z.showPersonNum();</span><br><span class="line">            v_m.showPersonNum();</span><br><span class="line"></span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br></pre></td></tr></table></figure>

