    <content><![CDATA[<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line"></span><br><span class="line">import java.util.Random;</span><br><span class="line">import java.util.Scanner;</span><br><span class="line"></span><br><span class="line">&#x2F;**</span><br><span class="line"> * @author : DolphinHome</span><br><span class="line"> * @date : 2020&#x2F;9&#x2F;25  12:13</span><br><span class="line"> *&#x2F;</span><br><span class="line">public class Test &#123;</span><br><span class="line"></span><br><span class="line">    public static void run_1() &#123;</span><br><span class="line">        int a &#x3D; 945 - 1;</span><br><span class="line"></span><br><span class="line">        &#x2F;*</span><br><span class="line">        希腊字母&#39;a&#39;在unicode表中的顺序位置: 945</span><br><span class="line">        希腊字母&#39;w&#39;在unicode表中的顺序位置: 969</span><br><span class="line">        希腊字母表:</span><br><span class="line">         *&#x2F;</span><br><span class="line">        System.out.println(&quot;希腊字母&#39;a&#39;在unicode表中的顺序位置:&quot; + (a + 1));</span><br><span class="line">        System.out.println(&quot;希腊字母&#39;w&#39;在unicode表中的顺序位置:&quot; + (a + 25));</span><br><span class="line">        System.out.println(&quot;希腊字母表:&quot;);</span><br><span class="line">        for (int i &#x3D; 1; i &lt;&#x3D; 24+1; i++) &#123;</span><br><span class="line">            if (i % 5 &#x3D;&#x3D; 0) &#123;</span><br><span class="line">                System.out.println((char) (a + i));</span><br><span class="line">            &#125; else &#123;</span><br><span class="line">                System.out.print((char) (a + i) + &quot;\t&quot;);</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line"></span><br><span class="line">    public static void run_2() &#123;</span><br><span class="line">        int start &#x3D; 1;</span><br><span class="line">        int stop &#x3D; 100;</span><br><span class="line">        Random random &#x3D; new Random();</span><br><span class="line">        int data &#x3D; random.nextInt(stop) % (stop - start + 1) + start;</span><br><span class="line">        Scanner scanner &#x3D; new Scanner(System.in);</span><br><span class="line">        int inData &#x3D; 0;</span><br><span class="line">        System.out.println(&quot;随机值： &quot; + data);</span><br><span class="line">        while (!((inData &#x3D; scanner.nextInt()) &#x3D;&#x3D; data)) &#123;</span><br><span class="line">            if (inData &gt; data) &#123;</span><br><span class="line">                System.out.println(inData + &quot;\t大了&quot;);</span><br><span class="line">            &#125; else if (inData &lt; data) &#123;</span><br><span class="line">                System.out.println(inData + &quot;\t小了&quot;);</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line">        System.out.println(&quot;正确！！&quot;);</span><br><span class="line">    &#125;</span><br><span class="line"></span><br><span class="line">    public static void run_3() &#123;</span><br><span class="line">        int[] a &#x3D; &#123;100, 200, 300&#125;;</span><br><span class="line">        System.out.println(&quot;数组长度:\t&quot; + a.length);</span><br><span class="line">        System.out.println(&quot;数组a的引用：&quot; + a);</span><br><span class="line">        int b[][] &#x3D; &#123;&#123;1&#125;, &#123;1, 1&#125;, &#123;1, 2, 1&#125;, &#123;1, 3, 3, 1&#125;, &#123;1, 4, 6, 4, 1&#125;&#125;;</span><br><span class="line">        System.out.println(&quot;二维数组的一维数组个数: &quot; + b.length);</span><br><span class="line">        System.out.println(b[4][2]);</span><br><span class="line">        &#x2F;&#x2F;将数组a的引用赋给b[4]</span><br><span class="line">        b[4] &#x3D; a;</span><br><span class="line">        System.out.println(b[4][2]);</span><br><span class="line">        try &#123;</span><br><span class="line">            a[3] &#x3D; 200;</span><br><span class="line">        &#125; catch (Exception e) &#123;</span><br><span class="line">            e.printStackTrace();</span><br><span class="line">        &#125;</span><br><span class="line">        for (int i &#x3D; 0; i &lt; b.length; i++) &#123;</span><br><span class="line">            System.out.println(&quot;数组b[&quot; + i + &quot;]&quot; + &quot;长度： &quot; + b[i].length + &quot;\t引用: &quot; + b[i]);</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">    &#125;</span><br><span class="line"></span><br><span class="line">    public static void main(String[] args) &#123;</span><br><span class="line">        run_1();</span><br><span class="line">        run_2();</span><br><span class="line">        run_3();</span><br><span class="line"></span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure><link rel="stylesheet" href="/css/spoiler.css" type="text/css"><script src="/js/spoiler.js" type="text/javascript" async></script>]]></content>
